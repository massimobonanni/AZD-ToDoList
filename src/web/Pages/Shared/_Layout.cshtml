<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — AZD Demo</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 700; letter-spacing: 0.5px; }
        .badge-azd { background: #0078d4; color: #fff; border-radius: 4px; padding: 2px 8px; font-size: 0.75rem; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-primary mb-4 shadow-sm">
        <div class="container">
            <span class="navbar-brand">&#9889; AZD ToDo List Demo</span>
            <span class="text-white-50 small">
                Deployed with <code class="text-white">azd up</code>
                &nbsp;&bull;&nbsp;
                App Service + Azure Functions + Table Storage
            </span>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="mt-5 py-3 bg-light border-top text-center text-muted small">
        Azure Developer CLI (AZD) Demo &bull; ASP.NET Core &bull; Managed Identity &bull; No secrets in code
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
