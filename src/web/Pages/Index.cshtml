@page
@model TaskDemo.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Task Manager";
}

<div class="container" style="max-width: 720px;">

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title">Add a Task</h5>
            <form method="post" asp-page-handler="Create">
                <div class="input-group">
                    <input type="text" class="form-control" name="title"
                           placeholder="Enter a task title..." maxlength="200" required />
                    <button class="btn btn-primary" type="submit">+ Add</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.ErrorMessage is not null)
    {
        <div class="alert alert-warning" role="alert">
            ⚠️ @Model.ErrorMessage
        </div>
    }

    <div class="list-group shadow-sm">
        @foreach (var task in Model.Tasks)
        {
            <div class="list-group-item d-flex justify-content-between align-items-center
                        @(task.IsCompleted ? "list-group-item-success" : "")">
                <div>
                    <span class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "fw-medium")">
                        @task.Title
                    </span>
                    <small class="text-muted d-block">@task.CreatedAt.ToLocalTime().ToString("g")</small>
                </div>
                <div class="d-flex gap-2">
                    @if (!task.IsCompleted)
                    {
                        <form method="post" asp-page-handler="Complete">
                            <input type="hidden" name="id" value="@task.Id" />
                            <button class="btn btn-sm btn-success" title="Mark complete">&#10003; Done</button>
                        </form>
                    }
                    <form method="post" asp-page-handler="Delete">
                        <input type="hidden" name="id" value="@task.Id" />
                        <button class="btn btn-sm btn-outline-danger" title="Delete task">&#x2715;</button>
                    </form>
                </div>
            </div>
        }

        @if (!Model.Tasks.Any())
        {
            <div class="list-group-item text-muted text-center py-5">
                No tasks yet — add one above!
            </div>
        }
    </div>

    @if (Model.Tasks.Any())
    {
        <p class="mt-3 text-muted small">
            @Model.Tasks.Count() task(s) total,
            @Model.Tasks.Count(t => t.IsCompleted) completed,
            @Model.Tasks.Count(t => !t.IsCompleted) remaining
        </p>
    }

</div>
